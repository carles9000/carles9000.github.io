/F0 10 Tf
1 0 0 1 25 450 Tm
(        FOR n := 1 TO LEN\( aDestino\))Tj
/F0 10 Tf
1 0 0 1 25 440 Tm
(            ?? aDestino [n][1])Tj
/F0 10 Tf
1 0 0 1 25 430 Tm
(        NEXT)Tj
/F0 10 Tf
1 0 0 1 25 420 Tm
()Tj
/F0 10 Tf
1 0 0 1 25 410 Tm
(        * segunda dimensiˇn)Tj
/F0 10 Tf
1 0 0 1 25 400 Tm
(        ? "Pares   son: "                // Resultado: es {2, 4, 6, 8, 10})Tj
/F0 10 Tf
1 0 0 1 25 390 Tm
(        FOR n := 1 TO LEN\( aDestino\))Tj
/F0 10 Tf
1 0 0 1 25 380 Tm
(            ?? aDestino [n][2])Tj
/F0 10 Tf
1 0 0 1 25 370 Tm
