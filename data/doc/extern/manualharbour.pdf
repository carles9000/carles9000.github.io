1 0 0 1 25 180 Tm
(  )Tj
/F0 10 Tf
1 0 0 1 25 170 Tm
(      LOCAL aNombre, aTamano, aFecha, aHora, aAtrib, nLen, i)Tj
/F0 10 Tf
1 0 0 1 25 160 Tm
(      nLen := ADIR\( "*.JPG" \)   // Nro de archivos JPG files en directorio)Tj
/F0 10 Tf
1 0 0 1 25 150 Tm
()Tj
/F0 10 Tf
1 0 0 1 25 140 Tm
(      IF nLen > 0)Tj
/F0 10 Tf
1 0 0 1 25 130 Tm
(         aNombre := Array\( nLen \)  // hace lugar para guardar la informaciˇn)Tj
/F0 10 Tf
1 0 0 1 25 120 Tm
(         aTamano := Array\( nLen \))Tj
/F0 10 Tf
1 0 0 1 25 110 Tm
(         aFecha := Array\( nLen \))Tj
/F0 10 Tf
1 0 0 1 25 100 Tm
(         aHora := Array\( nLen \))Tj
/F0 10 Tf
1 0 0 1 25 90 Tm
(         aAtrib := Array\( nLen \))Tj
/F0 10 Tf
1 0 0 1 25 80 Tm
(         FOR i = 1 TO nLen)Tj
/F0 10 Tf
1 0 0 1 25 70 Tm
(             ? aNombre[i], aTamano[i], aFecha[i], aHora[i], aAtrib[i])Tj
/F0 10 Tf
1 0 0 1 25 60 Tm
(         NEXT)Tj
/F0 10 Tf
1 0 0 1 25 50 Tm
(      ELSE)Tj
/F0 10 Tf
1 0 0 1 25 40 Tm
(         ? "Este directorio no tiene ni pelusa")Tj
ET
